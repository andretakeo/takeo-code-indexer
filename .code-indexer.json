{
  "include": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "constants/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}",
    "db/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "scripts/**/*.{ts,tsx,js}"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/dist/**",
    "expo-env.d.ts",
    "**/.code-indexer/**"
  ],
  "chunkMaxLines": 50,
  "chunkOverlap": 10,
  "embedding": {
    "provider": "ollama",
    "model": "granite-embedding:30m",
    "dimensions": 384,
    "baseUrl": "http://localhost:11434"
  }
}
